# ================================================
# SababPDF Environment Variables
# Copy this to .env.local and fill in your values
# ================================================

# Backend API URL (your Express server)
# If running locally: http://localhost:5000
# If on AWS EC2: http://YOUR_EC2_IP:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google AdSense Publisher ID
# Get this from Google AdSense dashboard
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_BANNER=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=1234567890
